# Auth tier: "plugin" (default) or "user"
CRISP_TIER=plugin

# Plugin tier: Plugin ID + Plugin Secret Key (from Crisp Marketplace)
# User tier: email + user token
CRISP_IDENTIFIER=your_plugin_id_or_email
CRISP_KEY=your_plugin_secret_or_user_token
CRISP_WEBSITE_ID=your_website_id_here

# Transport: "stdio" (local/Claude Desktop) or "http" (Railway/remote)
MCP_TRANSPORT=http

# Port for HTTP mode (Railway sets this automatically)
PORT=3000
