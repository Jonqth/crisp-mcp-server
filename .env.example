CRISP_IDENTIFIER=your_plugin_id_here
CRISP_KEY=your_plugin_secret_here
CRISP_WEBSITE_ID=your_website_id_here

# Transport: "stdio" (local/Claude Desktop) or "http" (Railway/remote)
MCP_TRANSPORT=http

# Port for HTTP mode (Railway sets this automatically)
PORT=3000

# Bearer token to protect the HTTP endpoint (generate a strong random value)
MCP_API_TOKEN=your_secret_token_here
